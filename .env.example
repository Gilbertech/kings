# Database Configuration
# SQLite (local development) - SQLite file will be created automatically
DATABASE_URL="file:./prisma/dev.db"

# Email Configuration
# Gmail Setup Instructions:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password generated

EMAIL_USER=info@kingslawadvocates.com
EMAIL_PASSWORD=your-app-password-here

# Application
NEXT_PUBLIC_APP_NAME=Kings Law Advocates

# Optional: For production, use a service like SendGrid or Resend
# SENDGRID_API_KEY=your-sendgrid-key
# RESEND_API_KEY=your-resend-key
